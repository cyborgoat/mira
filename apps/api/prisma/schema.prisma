generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  role         UserRole @default(superuser)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamNode {
  id        String     @id
  parentId  String?
  name      String
  title     String?
  sortOrder Int        @default(0)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    TeamNode?  @relation("TeamNodeChildren", fields: [parentId], references: [id])
  children  TeamNode[] @relation("TeamNodeChildren")
  tasks     Task[]
  notes     MeetingNote[]

  @@index([parentId, sortOrder])
  @@index([active])
}

model Task {
  id          String     @id
  ownerNodeId String
  title       String
  details     String     @default("")
  status      TaskStatus @default(open)
  priority    TaskPriority @default(normal)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt
  owner       TeamNode   @relation(fields: [ownerNodeId], references: [id])

  @@index([ownerNodeId, status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdAt])
  @@index([completedAt])
}

model MeetingNote {
  id          String   @id
  ownerNodeId String
  title       String
  date        DateTime
  content     String   @default("")
  tags        String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       TeamNode @relation(fields: [ownerNodeId], references: [id])

  @@index([ownerNodeId, date])
}

enum UserRole {
  superuser
}

enum TaskStatus {
  open
  complete
}

enum TaskPriority {
  low
  normal
  high
  urgent
}
