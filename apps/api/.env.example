# Mira API Environment Configuration
# Copy this file to apps/api/.env and fill in your values.

# Database
# Defaults to a local SQLite database in ./mira-workspace/mira-api.sqlite3 when unset.
MIRA_DATABASE_URL=

# Authentication
MIRA_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32
MIRA_JWT_ACCESS_EXPIRY=1d
MIRA_BCRYPT_ROUNDS=12

# CORS Origins (comma-separated). Localhost and 127.0.0.1 ports are allowed in development by default.
MIRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# LLM Wiki and Ask Mira AI provider fallback.
# Prefer configuring these values in the Settings > LLM config UI.
# Supported providers: openai, openrouter, anthropic, custom-openai-compatible
MIRA_AI_PROVIDER=openai
MIRA_AI_API_KEY=
MIRA_AI_BASE_URL=https://api.openai.com/v1
MIRA_AI_MODEL=gpt-5.2
MIRA_AI_MAX_TOKENS=4000
MIRA_AI_TIMEOUT_MS=45000
# When true, LLM endpoints require X-Mira-AI-Manual: 1 (set by explicit user actions in the UI).
MIRA_AI_REQUIRE_MANUAL_HEADER=
MIRA_LLM_CONFIG_ROOT=

# Workspace, LLM Wiki, and Ask Mira content roots.
# Defaults live under ./mira-workspace at the repository root when unset.
MIRA_WORKSPACE_ROOT=
MIRA_WIKI_ROOT=
MIRA_WIKI_MAX_SOURCE_BYTES=1000000
MIRA_WIKI_SOURCE_PROMPT_CHARS=60000
MIRA_WIKI_CONTEXT_CHARS=90000

# Proxy behavior for AI provider requests:
# empty = use HTTPS_PROXY/https_proxy from the system environment when present
# off = bypass proxy
# http://127.0.0.1:7897 = use this proxy instead of the system proxy
MIRA_AI_PROXY=
