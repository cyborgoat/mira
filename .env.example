# Mira Local Environment Configuration
# Copy this file to .env and fill in your values.

# ==============================================================================
# Database Configuration
# ==============================================================================
# Defaults to a local SQLite database in ./mira-workspace/mira-api.sqlite3 when unset.
# Prisma accepts SQLite URLs such as file:../../mira-workspace/mira-api.sqlite3.
MIRA_DATABASE_URL=

# ==============================================================================
# Mira NestJS API Configuration
# ==============================================================================

# Seeded superuser for local/admin Settings access.
# Additional mock users are seeded for local testing:
# manager@mira.local, alex@mira.local, sam@mira.local
# They use MIRA_SUPERUSER_PASSWORD by default in local seed data.
MIRA_SUPERUSER_EMAIL=admin@mira.local
MIRA_SUPERUSER_PASSWORD=local-password

# JWT Authentication
# Generate with: openssl rand -hex 32
MIRA_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# JWT Token Expiry (seconds)
MIRA_JWT_ACCESS_EXPIRY=1d

# Password Hashing
MIRA_BCRYPT_ROUNDS=12

# CORS Origins (comma-separated). Localhost and 127.0.0.1 ports are allowed in development by default.
MIRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Web API base URL
VITE_MIRA_API_URL=http://127.0.0.1:8000

# ==============================================================================
# AI Summarizer Configuration (backend only)
# ==============================================================================
# Supported providers: openai, openrouter, anthropic, custom-openai-compatible
# OpenAI example:
# MIRA_AI_PROVIDER=openai
# MIRA_AI_BASE_URL=https://api.openai.com/v1
# MIRA_AI_MODEL=gpt-5.2
#
# OpenRouter example:
# MIRA_AI_PROVIDER=openrouter
# MIRA_AI_BASE_URL=https://openrouter.ai/api/v1
# MIRA_AI_MODEL=openai/gpt-5.2
#
# Anthropic example:
# MIRA_AI_PROVIDER=anthropic
# MIRA_AI_BASE_URL=https://api.anthropic.com
# MIRA_AI_MODEL=claude-3-5-sonnet-latest
MIRA_AI_PROVIDER=openai
MIRA_AI_API_KEY=
MIRA_AI_BASE_URL=https://api.openai.com/v1
MIRA_AI_MODEL=gpt-5.2
MIRA_AI_TIMEOUT_MS=45000
MIRA_AI_APP_URL=http://localhost:5173
MIRA_AI_APP_NAME=Mira

# Application Settings
MIRA_DEBUG=false
MIRA_MAX_UPLOAD_BYTES=2097152     # 2MB
MIRA_DEFAULT_LANGUAGE=en

# ==============================================================================
# Security Notes
# ==============================================================================
# 1. NEVER commit .env to version control
# 2. Use a strong, unique value for MIRA_JWT_SECRET
# 3. In production, use a secrets manager instead of .env files
# 4. Update MIRA_CORS_ORIGINS to match your production domain
