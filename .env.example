# Mira Docker Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================
POSTGRES_USER=mira
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_DB=mira
POSTGRES_PORT=5432

# ==============================================================================
# Mira API Configuration
# ==============================================================================

# JWT Authentication (REQUIRED)
# Generate with: openssl rand -hex 32
MIRA_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# JWT Token Expiry (seconds)
MIRA_JWT_ACCESS_EXPIRY=900        # 15 minutes
MIRA_JWT_REFRESH_EXPIRY=604800    # 7 days

# Password Hashing
MIRA_BCRYPT_ROUNDS=12

# CORS Origins (comma-separated)
MIRA_CORS_ORIGINS=http://localhost,http://localhost:80

# Application Settings
MIRA_DEBUG=false
MIRA_MAX_UPLOAD_BYTES=2097152     # 2MB
MIRA_DEFAULT_LANGUAGE=en

# ==============================================================================
# Port Configuration
# ==============================================================================
API_PORT=8000
WEB_PORT=80

# ==============================================================================
# Security Notes
# ==============================================================================
# 1. NEVER commit .env to version control
# 2. Use strong, unique values for POSTGRES_PASSWORD and MIRA_JWT_SECRET
# 3. In production, use a secrets manager instead of .env files
# 4. Update MIRA_CORS_ORIGINS to match your production domain
