# Mira Local Environment Configuration
# Copy this file to .env and fill in your values

# ==============================================================================
# Database Configuration
# ==============================================================================
# Defaults to a local SQLite database in ./mira-workspace when unset.
# Use PostgreSQL by setting a URL like:
# MIRA_DATABASE_URL=postgresql://mira:password@localhost:5432/mira
MIRA_DATABASE_URL=

# ==============================================================================
# Mira API Configuration
# ==============================================================================

# JWT Authentication (REQUIRED)
# Generate with: openssl rand -hex 32
MIRA_JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# JWT Token Expiry (seconds)
MIRA_JWT_ACCESS_EXPIRY=900        # 15 minutes
MIRA_JWT_REFRESH_EXPIRY=604800    # 7 days

# Password Hashing
MIRA_BCRYPT_ROUNDS=12

# CORS Origins (comma-separated)
MIRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Application Settings
MIRA_DEBUG=false
MIRA_MAX_UPLOAD_BYTES=2097152     # 2MB
MIRA_DEFAULT_LANGUAGE=en

# ==============================================================================
# Security Notes
# ==============================================================================
# 1. NEVER commit .env to version control
# 2. Use a strong, unique value for MIRA_JWT_SECRET
# 3. In production, use a secrets manager instead of .env files
# 4. Update MIRA_CORS_ORIGINS to match your production domain
